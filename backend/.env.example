# Copy to .env for local dev, or set these as env vars on your deploy host.

# Required — auth/chat features error without these, but standings/calendar/
# analysis routes have zero dependency on either (a missing/unreachable Mongo
# no longer crashes the whole process, only Mongo-backed routes).
MONGO_URI=mongodb://localhost:27017/gridlock
JWT_SECRET=change-me-to-a-long-random-string
GEMINI_API_KEY=your-gemini-api-key

# CORS allow-list for the deployed frontend — comma-separated for multiple
# origins (e.g. a production domain + Vercel preview deployments).
# Defaults to the local Vite dev origins if unset.
FRONTEND_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Server port (defaults to 5050 if unset).
PORT=5050

# Which season the hourly scheduler keeps refreshing (defaults to 2026).
CURRENT_SEASON=2026

# Python interpreter used to invoke data_scripts/*.py — defaults to
# data_scripts/venv/bin/python if unset (the Dockerfile sets this explicitly).
PYTHON_BIN=

# Where generated JSON (season standings/calendar + per-race telemetry) and
# FastF1's own raw HTTP cache live. Default to paths inside the repo for local
# dev; on a host with no persistent disk (e.g. Render's free tier), these are
# plain ephemeral container paths instead — persistence there comes from the
# GitHub-backed sync below, not a mounted volume.
CACHE_DIR=
FASTF1_CACHE_DIR=

# Makes a public GitHub repo the durable store for generated output (season
# standings/calendar + per-race telemetry JSON), so a host with no persistent
# disk still survives restarts/redeploys — see services/dataRepoSync.ts. Leave
# unset for local dev (CACHE_DIR is already persistent on disk).
GITHUB_DATA_TOKEN=
GITHUB_DATA_REPO=

# Same idea, for FastF1's own raw HTTP response cache specifically. Without
# this, that cache is wiped on every restart/redeploy, so the next request for
# a not-yet-generated race has to re-fetch its raw timing data from FastF1's
# servers from scratch — measured taking most of 10 minutes on Render's free
# tier, easily enough to make generation time out. Falls back to
# GITHUB_DATA_TOKEN if unset (a single fine-grained PAT can be scoped to cover
# both repos) — only GITHUB_FASTF1_CACHE_REPO is required to enable this.
GITHUB_FASTF1_CACHE_TOKEN=
GITHUB_FASTF1_CACHE_REPO=
